# ── Stage 1: Build Vite app ───────────────────────────────────────────────────
FROM node:24-slim AS builder

WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./

# Copy package.json stubs for ALL workspace packages so pnpm computes
# identical overrides to the lockfile (partial workspace causes mismatch).
COPY lib/db/package.json                   ./lib/db/
COPY artifacts/api-server/package.json     ./artifacts/api-server/
COPY artifacts/mockup-sandbox/package.json ./artifacts/mockup-sandbox/
COPY scripts/package.json                  ./scripts/

# Full source for the packages we actually build
COPY lib/api-spec/         ./lib/api-spec/
COPY lib/api-zod/          ./lib/api-zod/
COPY lib/api-client-react/ ./lib/api-client-react/
COPY artifacts/kds/        ./artifacts/kds/

RUN pnpm install --frozen-lockfile

# Build shared libs, then the frontend
RUN pnpm run typecheck:libs || true
RUN pnpm --filter @workspace/kds run build

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runner

# Remove default nginx content
RUN rm -rf /usr/share/nginx/html/*

# Copy built assets
COPY --from=builder /workspace/artifacts/kds/dist/public /usr/share/nginx/html

# Nginx config is mounted from docker-compose (nginx/kds.conf)
# but we provide a sensible default here
COPY docker/nginx-kds-default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:80/ || exit 1
