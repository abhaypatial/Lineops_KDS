# KDS — Environment Variables
# Copy this to .env and fill in your values.
# The install.sh script generates .env automatically with secure random secrets.

# Copy this file:
#   Linux / macOS / WSL:  cp .env.example .env
#   Windows PowerShell:   Copy-Item .env.example .env
#   Windows CMD:          copy .env.example .env
# Then run:  docker compose up -d --build

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL container.
# Generated automatically by install.sh — change only if you know what you're doing.
DB_PASSWORD=change_me

# ── Server ────────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Must be long and random.
SESSION_SECRET=change_me_to_a_long_random_string

# ── Network ───────────────────────────────────────────────────────────────────
# Port exposed on the host for the nginx reverse proxy (default: 80).
# Change if port 80 is already in use (e.g. IIS on Windows or another web server).
# HOST_PORT=8080

# The port exposed on the host for direct API access by the CLI (localhost only).
# Default: 3000. Change if another service is already using this port.
# API_PORT=3000

# ── POS Integration Secrets ───────────────────────────────────────────────────
# Webhook signing secrets for each POS system. Set the same value in the POS
# back office so signatures can be verified. Leave blank to skip verification.

# Volante Systems VE POS
# RPC push mode: VE calls LineOps. Set the same value in VE Back Office as your signing secret.
# VOLANTE_WEBHOOK_SECRET=change_me
#
# KDS Terminal ID → station mapping (JSON object).
# Keys are the "KDS Terminal ID" integers from VE Back Office → Kitchen Display Setup → Terminal group.
# Values are LineOps station IDs (from your Stations setup page).
# VE sends this integer (pluginId) in every kitchen job — it's the simplest routing key.
# Without this, station routing falls back to item groupName keyword matching.
# VOLANTE_STATION_MAP={"1":"grill","2":"cold","3":"fryer","4":"dessert"}
#
# Pull / callback mode: LineOps calls VE API (pos, menu, transaction services).
# VOLANTE_HOST=https://your-tenant.volantecloud.com
# VOLANTE_CLIENT_ID=your-client-id
# VOLANTE_CLIENT_SECRET=your-client-secret

# Square — set in Square Developer Dashboard → Webhooks → Signature Key
# SQUARE_WEBHOOK_SECRET=change_me

# Toast POS — set in Toast Back Office → API Access → Webhook Secret
# TOAST_WEBHOOK_SECRET=change_me

# Clover — set to the OAuth bearer token issued to your app
# CLOVER_WEBHOOK_SECRET=change_me

# Lightspeed K-Series — set in Lightspeed → Settings → Webhooks
# LIGHTSPEED_WEBHOOK_SECRET=change_me

# ── Admin & Feature Flags ─────────────────────────────────────────────────────
# Password protecting the management interface.
# Leave blank to disable authentication (suitable for a trusted LAN).
# Set this for any network that is not fully private.
# ADMIN_PASSWORD=pwd123!

# Set to false to disable the test-order injection button on the KDS display.
# Always disable this on a live production system.
# ALLOW_TEST_ORDERS=true

# Comma-separated list of POS system IDs to hide in the Integration Hub.
# Supported IDs: square, toast, clover, lightspeed, volante, generic
# HIDDEN_INTEGRATIONS=

# ── Store identity ────────────────────────────────────────────────────────────
# Display name shown in the admin and on receipts.
# KDS_STORE_NAME=My Restaurant
